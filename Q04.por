programa
{
	funcao inicio()
	{
		cadeia cores[3]

		escreva("Digite a primeira cor: ")
		leia(cores[0])

		escreva("Digite a segunda cor: ")
		leia(cores[1])

		escreva("Digite a terceira cor: ")
		leia(cores[2])

		escreva("\nOrdem inversa:\n")
		escreva(cores[2], "\n")
		escreva(cores[1], "\n")
		escreva(cores[0], "\n")
	}
}
